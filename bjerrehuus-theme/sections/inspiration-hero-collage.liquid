{{ 'bjerrehuus-inspiration.css' | asset_url | stylesheet_tag }}

<section class="bjfj-insp-section bjfj-insp-hero">

  {%- if section.settings.hero_image != blank -%}
    {{
      section.settings.hero_image
      | image_url: width: 2400
      | image_tag:
        class: 'bjfj-insp-hero__image',
        loading: 'eager',
        fetchpriority: 'high',
        alt: section.settings.hero_label
    }}
  {%- elsif section.settings.hero_image_url != blank -%}
    <img src="{{ section.settings.hero_image_url }}" class="bjfj-insp-hero__image" loading="eager" fetchpriority="high" alt="{{ section.settings.hero_label | escape }}">
  {%- else -%}
    {{ 'lifestyle' | placeholder_svg_tag: 'bjfj-insp-hero__image' }}
  {%- endif -%}

  <div class="bjfj-insp-hero__scrim"></div>

  {%- comment %} Overlay text elements — positioned absolutely over the image {%- endcomment %}
  {%- if section.blocks.size > 0 -%}
    <div class="bjfj-insp-hero__overlays" aria-hidden="true">
      {%- for block in section.blocks -%}
        {%- if block.type == 'overlay_text' and block.settings.text != blank -%}
          <p
            class="bjfj-insp-hero__overlay bjfj-insp-hero__overlay--{{ block.settings.position }}"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.text }}
          </p>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}

  <div class="bjfj-insp-hero__content bjfj-reveal">
    {%- if section.settings.hero_label != blank -%}
      <p class="bjfj-insp-hero__label">{{ section.settings.hero_label }}</p>
    {%- endif -%}
    {%- if section.settings.hero_headline != blank -%}
      <h1 class="bjfj-insp-hero__headline">{{ section.settings.hero_headline }}</h1>
    {%- endif -%}
    {%- if section.settings.hero_body != blank -%}
      <div class="bjfj-insp-hero__body">{{ section.settings.hero_body }}</div>
    {%- endif -%}
  </div>

</section>

{% schema %}
{
  "name": "Inspiration: Hero",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "hero_image_url",
      "label": "Hero image URL (fallback)"
    },
    {
      "type": "text",
      "id": "hero_label",
      "label": "Collection label",
      "placeholder": "THE PILLOW",
      "info": "Displayed above the headline in small caps"
    },
    {
      "type": "text",
      "id": "hero_headline",
      "label": "Headline"
    },
    {
      "type": "richtext",
      "id": "hero_body",
      "label": "Body text"
    }
  ],
  "blocks": [
    {
      "type": "overlay_text",
      "name": "Overlay text",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "select",
          "id": "position",
          "label": "Position",
          "options": [
            { "value": "top-left", "label": "Top left" },
            { "value": "top-right", "label": "Top right" },
            { "value": "mid-right", "label": "Middle right" }
          ],
          "default": "top-right"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Inspiration: Hero"
    }
  ]
}
{% endschema %}
