{{ 'bjerrehuus-inspiration.css' | asset_url | stylesheet_tag }}

{%- assign hero_treatment = section.settings.hero_treatment | default: 'standard' -%}
{%- assign scrim_strength = section.settings.scrim_strength | default: 'medium' -%}

<section
  class="bjfj-insp-section bjfj-insp-hero bjfj-insp-hero--{{ hero_treatment | handleize }} bjfj-insp-hero--scrim-{{ scrim_strength }}"
  data-hero-treatment="{{ hero_treatment | escape }}"
>

  {%- if section.settings.hero_image != blank -%}
    {{
      section.settings.hero_image
      | image_url: width: 2400
      | image_tag:
        class: 'bjfj-insp-hero__image',
        loading: 'eager',
        fetchpriority: 'high',
        alt: section.settings.hero_label
    }}
  {%- elsif section.settings.hero_image_url != blank -%}
    {%- liquid
      assign hero_image_src = section.settings.hero_image_url
      unless hero_image_src contains '://'
        assign hero_image_src = hero_image_src | asset_url
      endunless
    -%}
    <img src="{{ hero_image_src }}" class="bjfj-insp-hero__image" style="object-position: {{ section.settings.hero_image_position | escape }};" loading="eager" fetchpriority="high" alt="{{ section.settings.hero_label | escape }}" width="2400" height="1600">
  {%- else -%}
    <img src="{{ 'lifestyle-5691.jpg' | asset_url }}" class="bjfj-insp-hero__image" style="object-position: {{ section.settings.hero_image_position | escape }};" loading="eager" fetchpriority="high" alt="{{ section.settings.hero_label | escape }}" width="2400" height="1600">
  {%- endif -%}

  <div class="bjfj-insp-hero__scrim"></div>

  {%- comment %} Overlay text elements — positioned absolutely over the image {%- endcomment %}
  {%- if section.blocks.size > 0 -%}
    <div class="bjfj-insp-hero__overlays" aria-hidden="true">
      {%- for block in section.blocks -%}
        {%- if block.type == 'overlay_text' and block.settings.text != blank -%}
          <p
            class="bjfj-insp-hero__overlay bjfj-insp-hero__overlay--{{ block.settings.position }}"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.text }}
          </p>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}

  <div class="bjfj-insp-hero__content bjfj-reveal">
    {%- if section.settings.hero_label != blank -%}
      <p class="bjfj-insp-hero__label">{{ section.settings.hero_label }}</p>
    {%- endif -%}
    {%- if section.settings.hero_headline != blank -%}
      <h1 class="bjfj-insp-hero__headline">{{ section.settings.hero_headline }}</h1>
    {%- endif -%}
    {%- if section.settings.hero_body != blank -%}
      <div class="bjfj-insp-hero__body">{{ section.settings.hero_body }}</div>
    {%- endif -%}
  </div>

</section>

{% schema %}
{
  "name": "Inspiration: Hero",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "hero_image_url",
      "label": "Hero image URL (fallback)"
    },
    {
      "type": "text",
      "id": "hero_image_position",
      "label": "Hero image focal point",
      "default": "center center",
      "info": "CSS object-position value, for example: center 72%"
    },
    {
      "type": "select",
      "id": "hero_treatment",
      "label": "Hero image treatment",
      "options": [
        {
          "value": "standard",
          "label": "Standard"
        },
        {
          "value": "pillow",
          "label": "Pillow right focus"
        }
      ],
      "default": "standard"
    },
    {
      "type": "select",
      "id": "scrim_strength",
      "label": "Scrim strength",
      "info": "Adjust darkening overlay for the image — increase if text becomes hard to read.",
      "options": [
        { "value": "light", "label": "Light (use on dark imagery)" },
        { "value": "medium", "label": "Medium (default)" },
        { "value": "strong", "label": "Strong (use on bright imagery)" }
      ],
      "default": "medium"
    },
    {
      "type": "text",
      "id": "hero_label",
      "label": "Collection label",
      "placeholder": "THE PILLOW",
      "info": "Displayed above the headline in small caps"
    },
    {
      "type": "text",
      "id": "hero_headline",
      "label": "Headline"
    },
    {
      "type": "richtext",
      "id": "hero_body",
      "label": "Body text"
    }
  ],
  "blocks": [
    {
      "type": "overlay_text",
      "name": "Overlay text",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "select",
          "id": "position",
          "label": "Position",
          "options": [
            { "value": "top-left", "label": "Top left" },
            { "value": "top-right", "label": "Top right" },
            { "value": "mid-right", "label": "Middle right" }
          ],
          "default": "top-right"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Inspiration: Hero"
    }
  ]
}
{% endschema %}
