{{ 'bjerrehuus-inspiration.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign fav_products = '' | split: ''
  for i in (1..3)
    assign key = 'product_' | append: i
    assign p = all_products[section.settings[key]]
    if p != empty
      assign fav_products = fav_products | concat: p.images
    endif
  endfor
  assign has_favorites = false
  for i in (1..3)
    assign key = 'product_' | append: i
    assign p = all_products[section.settings[key]]
    if p != empty
      assign has_favorites = true
      break
    endif
  endfor
-%}

{%- if has_favorites -%}
<section class="bjfj-universe-section bjfj-universe-favorites">
  <div class="bjfj-universe-inner">

    <div class="bjfj-universe-favorites__header bjfj-reveal">
      {%- if section.settings.label != blank -%}
        <p class="bjfj-universe-favorites__label">{{ section.settings.label }}</p>
      {%- endif -%}
      <h2 class="bjfj-universe-favorites__heading">{{ section.settings.heading | default: 'My Favorites' }}</h2>
    </div>

    <ul class="bjfj-universe-favorites__grid" role="list">
      {%- for i in (1..3) -%}
        {%- liquid
          assign key = 'product_' | append: i
          assign fav = all_products[section.settings[key]]
        -%}
        {%- if fav != empty -%}
          {%- liquid
            assign fav_var      = fav.selected_or_first_available_variant
            assign fav_material = fav.metafields.custom.material.value
            assign fav_img2     = fav.images[1]
          -%}
          <li class="bjfj-insp-card bjfj-reveal">

            <div class="bjfj-insp-card__image-wrap">
              {%- if fav.featured_image != blank -%}
                {{
                  fav.featured_image
                  | image_url: width: 800
                  | image_tag:
                    class: 'bjfj-insp-card__image',
                    loading: 'lazy',
                    alt: fav.title
                }}
                {%- if fav_img2 != blank -%}
                  {{
                    fav_img2
                    | image_url: width: 800
                    | image_tag:
                      class: 'bjfj-insp-card__image-alt',
                      loading: 'lazy',
                      alt: fav.title
                  }}
                {%- endif -%}
              {%- else -%}
                {{ 'product-4' | placeholder_svg_tag: 'bjfj-insp-card__image' }}
              {%- endif -%}
            </div>

            <p class="bjfj-insp-card__name">{{ fav.title }}</p>
            {%- if fav_material != blank -%}
              <p class="bjfj-insp-card__meta">{{ fav_material }}</p>
            {%- endif -%}
            <p class="bjfj-insp-card__price">{{ fav_var.price | money }}</p>

            <div class="bjfj-insp-card__cta">
              <button
                type="button"
                class="bjfj-btn--inquire-outline"
                data-inquire-trigger
                data-product-name="{{ fav.title | escape }}"
                data-product-material="{{ fav_material | escape }}"
                data-product-price="{{ fav_var.price | money }}"
                data-product-img="{{ fav.featured_image | image_url: width: 300 }}"
                data-product-handle="{{ fav.handle }}"
                data-product-url="{{ shop.url }}{{ fav.url }}"
              >
                Inquire
              </button>
            </div>

          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>

  </div>
</section>

{%- render 'inquire-letter-modal' -%}

{%- endif -%}

{% schema %}
{
  "name": "Universe: Favorites",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Eyebrow label",
      "default": "Vibe's picks"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "My Favorites"
    },
    {
      "type": "product",
      "id": "product_1",
      "label": "Product 1"
    },
    {
      "type": "product",
      "id": "product_2",
      "label": "Product 2"
    },
    {
      "type": "product",
      "id": "product_3",
      "label": "Product 3"
    }
  ],
  "presets": [
    {
      "name": "Universe: Favorites"
    }
  ]
}
{% endschema %}
