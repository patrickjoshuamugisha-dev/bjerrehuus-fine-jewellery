{{ 'bjerrehuus-collection.css' | asset_url | stylesheet_tag }}

{%- if collection.handle == 'all' and section.blocks.size > 0 -%}
  <div class="bjfj-campaign-tiles bjfj-reveal-stagger">
    {%- for block in section.blocks -%}
      <a
        class="bjfj-campaign-tile bjfj-reveal"
        href="{{ block.settings.link | default: '#' }}"
        style="--tile-focal-x: {{ block.settings.focal_x | default: 50 }}%; --tile-focal-y: {{ block.settings.focal_y | default: 50 }}%; --tile-scale: {{ block.settings.scale | default: 100 | divided_by: 100.0 }};"
        {{ block.shopify_attributes }}
      >
        <div class="bjfj-campaign-tile__bg">
          {%- if block.settings.image -%}
            <img
              src="{{ block.settings.image | image_url: width: 900 }}"
              srcset="
                {{ block.settings.image | image_url: width: 600 }} 600w,
                {{ block.settings.image | image_url: width: 900 }} 900w,
                {{ block.settings.image | image_url: width: 1200 }} 1200w
              "
              sizes="(max-width: 749px) 78vw, 33vw"
              alt="{{ block.settings.image.alt | default: block.settings.label | escape }}"
              loading="lazy"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
            >
          {%- elsif block.settings.image_url != blank -%}
            {%- liquid
              assign campaign_image_src = block.settings.image_url
              unless campaign_image_src contains '://'
                assign campaign_image_src = campaign_image_src | asset_url
              endunless
            -%}
            <img
              src="{{ campaign_image_src }}"
              sizes="(max-width: 749px) 78vw, 33vw"
              alt="{{ block.settings.label | escape }}"
              loading="lazy"
              width="900"
              height="1200"
            >
          {%- else -%}
            {{ 'collection-apparel-1' | placeholder_svg_tag: 'bjfj-campaign-tile__placeholder' }}
          {%- endif -%}
        </div>
        <div class="bjfj-campaign-tile__label">
          <span>{%- if block.settings.label != blank -%}{{ block.settings.label }}{%- else -%}{{ 'bjerrehuus.campaign_tiles.default_label' | t }}{%- endif -%}</span>
        </div>
      </a>
    {%- endfor -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Campaign tiles",
  "tag": "div",
  "class": "bjfj-campaign-tiles-section",
  "max_blocks": 3,
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "Image URL (fallback)",
          "info": "Used when no image is selected above. Paste a Shopify CDN URL."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "THE COLLECTION",
          "info": "Displayed in uppercase over the image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "range",
          "id": "focal_x",
          "min": 0,
          "max": 100,
          "step": 5,
          "unit": "%",
          "label": "Focal point X",
          "default": 50
        },
        {
          "type": "range",
          "id": "focal_y",
          "min": 0,
          "max": 100,
          "step": 5,
          "unit": "%",
          "label": "Focal point Y",
          "default": 50
        },
        {
          "type": "range",
          "id": "scale",
          "min": 100,
          "max": 150,
          "step": 5,
          "unit": "%",
          "label": "Zoom / scale",
          "default": 100
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Campaign tiles",
      "blocks": [
        {
          "type": "tile",
          "settings": {
            "label": "THE PILLOW",
            "link": "/pages/pillow"
          }
        },
        {
          "type": "tile",
          "settings": {
            "label": "THE SECOND"
          }
        },
        {
          "type": "tile",
          "settings": {
            "label": "THE THIRD"
          }
        }
      ]
    }
  ]
}
{% endschema %}
