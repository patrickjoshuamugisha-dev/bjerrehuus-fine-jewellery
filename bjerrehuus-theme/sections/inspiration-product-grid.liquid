{{ 'bjerrehuus-inspiration.css' | asset_url | stylesheet_tag }}
<script src="{{ 'bjerrehuus-product.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign grid_collection = section.settings.collection
  if grid_collection == blank or grid_collection == empty
    assign grid_collection = collections[section.settings.collection]
  endif
  assign products_to_show = section.settings.products_to_show | default: 6
-%}

<section class="bjfj-insp-section bjfj-insp-grid">
  <div class="bjfj-insp-inner">

    <div class="bjfj-insp-grid__header bjfj-reveal">
      {%- if section.settings.heading != blank -%}
        <h2 class="bjfj-insp-grid__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if grid_collection != empty and grid_collection.products_count > 0 -%}
        <span class="bjfj-insp-grid__count">{{ grid_collection.products_count }} pieces</span>
      {%- endif -%}
    </div>

    {%- if grid_collection != empty and grid_collection.products_count > 0 -%}
      <ul class="bjfj-insp-product-grid" role="list">
        {%- for product in grid_collection.products limit: products_to_show -%}
          {%- liquid
            assign p_material = product.metafields.custom.material.value
            assign p_var      = product.selected_or_first_available_variant
            assign p_img2     = product.images[1]
          -%}
          <li class="bjfj-insp-card bjfj-reveal">

            <div class="bjfj-insp-card__image-wrap">
              {%- if product.featured_image != blank -%}
                {{
                  product.featured_image
                  | image_url: width: 800
                  | image_tag:
                    class: 'bjfj-insp-card__image',
                    loading: 'lazy',
                    alt: product.title
                }}
                {%- if p_img2 != blank -%}
                  {{
                    p_img2
                    | image_url: width: 800
                    | image_tag:
                      class: 'bjfj-insp-card__image-alt',
                      loading: 'lazy',
                      alt: product.title
                  }}
                {%- endif -%}
              {%- else -%}
                {{ 'product-4' | placeholder_svg_tag: 'bjfj-insp-card__image' }}
              {%- endif -%}
            </div>

            <p class="bjfj-insp-card__name">{{ product.title }}</p>
            {%- if p_material != blank -%}
              <p class="bjfj-insp-card__meta">{{ p_material }}</p>
            {%- endif -%}
            <p class="bjfj-insp-card__price">{{ p_var.price | money }}</p>

            <div class="bjfj-insp-card__cta">
              <button
                type="button"
                class="bjfj-btn--inquire-outline"
                data-inquire-trigger
                data-product-name="{{ product.title | escape }}"
                data-product-material="{{ p_material | escape }}"
                data-product-price="{{ p_var.price | money }}"
                data-product-img="{{ product.featured_image | image_url: width: 300 }}"
                data-product-handle="{{ product.handle }}"
                data-product-url="{{ shop.url }}{{ product.url }}"
              >
                Inquire
              </button>
            </div>

          </li>
        {%- endfor -%}
      </ul>

    {%- else -%}
      <div class="bjfj-insp-grid__soon">
        <p class="bjfj-insp-grid__soon-eyebrow">By appointment</p>
        <p class="bjfj-insp-grid__soon-line">New pieces are arriving this season.</p>
        <button
          type="button"
          class="bjfj-btn--inquire-outline"
          data-inquire-trigger
          data-product-name="{{ grid_collection.title | default: section.settings.heading | escape }}"
          data-product-material=""
          data-product-price=""
          data-product-img=""
          data-product-handle=""
          data-product-url="{{ shop.url }}{{ request.path }}"
        >
          Inquire about a piece
        </button>
      </div>
    {%- endif -%}

  </div>
</section>

{%- comment %} Modal rendered once per page — JS opens it per trigger {%- endcomment %}
{%- render 'inquire-letter-modal' -%}

{% schema %}
{
  "name": "Inspiration: Grid",
  "tag": "section",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "All products will show INQUIRE buttons regardless of purchase_type"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "The Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 3,
      "max": 12,
      "step": 3,
      "default": 6,
      "label": "Products to show"
    }
  ],
  "presets": [
    {
      "name": "Inspiration: Grid"
    }
  ]
}
{% endschema %}
