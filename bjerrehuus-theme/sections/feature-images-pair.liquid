{{ 'bjerrehuus-homepage.css' | asset_url | stylesheet_tag }}

<section class="bjfj-pair{% if section.settings.bg_color == 'alt' %} bjfj-pair--alt{% endif %}">

  <div class="bjfj-pair__images bjfj-reveal">
    {%- for i in (1..2) -%}
      {%- assign img_key = 'image_' | append: i -%}
      {%- assign url_key = 'image_' | append: i | append: '_url' -%}
      {%- if section.settings[img_key] != blank -%}
        {{
          section.settings[img_key]
          | image_url: width: 1200
          | image_tag:
            class: 'bjfj-pair__img',
            loading: 'lazy',
            alt: section.settings.heading | escape
        }}
      {%- elsif section.settings[url_key] != blank -%}
        {%- liquid
          assign pair_image_src = section.settings[url_key]
          unless pair_image_src contains '://'
            assign pair_image_src = pair_image_src | asset_url
          endunless
        -%}
        <img
          src="{{ pair_image_src }}"
          class="bjfj-pair__img"
          width="1200"
          height="1600"
          loading="lazy"
          alt="{{ section.settings.heading | escape }}"
        >
      {%- else -%}
        {%- liquid
          if i == 1
            assign fallback_asset = 'lifestyle-5794.jpg'
          else
            assign fallback_asset = 'lifestyle-love.jpg'
          endif
        -%}
        <img
          src="{{ fallback_asset | asset_url }}"
          class="bjfj-pair__img"
          width="1200"
          height="1600"
          loading="lazy"
          alt="{{ section.settings.heading | escape }}"
        >
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div class="bjfj-pair__text bjfj-reveal">
    {%- if section.settings.eyebrow != blank -%}
      <p class="bjfj-pair__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="bjfj-pair__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <div class="bjfj-pair__body">{{ section.settings.body }}</div>
    {%- endif -%}
    {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
      <a href="{{ section.settings.cta_url }}" class="bjfj-pair__cta">{{ section.settings.cta_label }}</a>
    {%- endif -%}
  </div>

</section>

{% schema %}
{
  "name": "Homepage: Feature Images",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1"
    },
    {
      "type": "text",
      "id": "image_1_url",
      "label": "Image 1 URL (fallback)"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2"
    },
    {
      "type": "text",
      "id": "image_2_url",
      "label": "Image 2 URL (fallback)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link"
    },
    {
      "type": "select",
      "id": "bg_color",
      "label": "Background",
      "options": [
        { "value": "default", "label": "Warm white" },
        { "value": "alt", "label": "Warm off-white" }
      ],
      "default": "default"
    }
  ],
  "presets": [
    {
      "name": "Homepage: Feature Images"
    }
  ]
}
{% endschema %}
