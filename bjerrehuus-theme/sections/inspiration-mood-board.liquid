{{ 'bjerrehuus-inspiration.css' | asset_url | stylesheet_tag }}

<section class="bjfj-insp-section bjfj-mood-board">
  <div class="bjfj-mood-board__inner">

    {%- if section.settings.section_label != blank -%}
      <p class="bjfj-mood-board__label">{{ section.settings.section_label }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="bjfj-mood-board__grid">
        {%- for block in section.blocks -%}

          {%- if block.type == 'image' -%}
            <figure class="bjfj-mood-board__cell bjfj-reveal" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 1200
                  | image_tag:
                    loading: 'lazy',
                    alt: block.settings.caption
                }}
              {%- elsif block.settings.image_url != blank -%}
                {%- liquid
                  assign mood_image_src = block.settings.image_url
                  unless mood_image_src contains '://'
                    assign mood_image_src = mood_image_src | asset_url
                  endunless
                -%}
                <img src="{{ mood_image_src }}" loading="lazy" alt="{{ block.settings.caption | escape }}" width="1200" height="900">
              {%- else -%}
                {{ 'image' | placeholder_svg_tag }}
              {%- endif -%}
              {%- if block.settings.caption != blank -%}
                <figcaption class="bjfj-mood-board__caption">{{ block.settings.caption }}</figcaption>
              {%- endif -%}
            </figure>

          {%- elsif block.type == 'bleeder_image' -%}
            <div class="bjfj-mood-board__cell bjfj-mood-board__bleeder bjfj-reveal" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 2400
                  | image_tag:
                    loading: 'lazy',
                    alt: block.settings.caption
                }}
              {%- elsif block.settings.image_url != blank -%}
                {%- liquid
                  assign bleeder_image_src = block.settings.image_url
                  unless bleeder_image_src contains '://'
                    assign bleeder_image_src = bleeder_image_src | asset_url
                  endunless
                -%}
                <img src="{{ bleeder_image_src }}" loading="lazy" alt="{{ block.settings.caption | escape }}" width="1200" height="900">
              {%- else -%}
                {{ 'lifestyle' | placeholder_svg_tag }}
              {%- endif -%}
            </div>

          {%- elsif block.type == 'pullquote' -%}
            <div class="bjfj-mood-board__pullquote bjfj-reveal" {{ block.shopify_attributes }}>
              {%- if block.settings.text != blank -%}
                <p>{{ block.settings.text }}</p>
              {%- endif -%}
            </div>

          {%- endif -%}

        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Inspiration — Mood Board",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "section_label",
      "label": "Section label",
      "placeholder": "The Collection",
      "info": "Appears above the grid in small olive caps"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "Image URL (fallback)"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Alt text / caption"
        }
      ]
    },
    {
      "type": "bleeder_image",
      "name": "Bleeder image",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "This image extends beyond the right edge of the viewport"
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "Image URL (fallback)"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Alt text"
        }
      ]
    },
    {
      "type": "pullquote",
      "name": "Pull quote",
      "limit": 2,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Quote text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Inspiration — Mood Board",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "pullquote" },
        { "type": "bleeder_image" }
      ]
    }
  ]
}
{% endschema %}
