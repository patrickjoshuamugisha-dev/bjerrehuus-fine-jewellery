{{ 'bjerrehuus-homepage.css' | asset_url | stylesheet_tag }}

{%- if section.blocks.size > 0 -%}
<section class="bjfj-tiles">
  <div class="bjfj-tiles__grid bjfj-reveal-stagger">
    {%- for block in section.blocks -%}
      {%- if block.type == 'tile' -%}
        <a
          href="{{ block.settings.link }}"
          class="bjfj-tile bjfj-reveal"
          aria-label="{{ block.settings.label | escape }}"
          style="--tile-focal-x: {{ block.settings.focal_x | default: 50 }}%; --tile-focal-y: {{ block.settings.focal_y | default: 50 }}%; --tile-scale: {{ block.settings.scale | default: 100 | divided_by: 100.0 }};"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 800
              | image_tag:
                class: 'bjfj-tile__img',
                loading: 'lazy',
                alt: block.settings.label | escape
            }}
          {%- elsif block.settings.image_url != blank -%}
            {%- liquid
              assign tile_image_src = block.settings.image_url
              unless tile_image_src contains '://'
                assign tile_image_src = tile_image_src | asset_url
              endunless
            -%}
            <img
              src="{{ tile_image_src }}"
              class="bjfj-tile__img"
              loading="lazy"
              alt="{{ block.settings.label | escape }}"
              width="800"
              height="1067"
            >
          {%- else -%}
            {{ 'lifestyle' | placeholder_svg_tag: 'bjfj-tile__img' }}
          {%- endif -%}
          <div class="bjfj-tile__scrim"></div>
          {%- if block.settings.label != blank -%}
            <span class="bjfj-tile__label">{{ block.settings.label }}</span>
          {%- endif -%}
        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Homepage: Discover Tiles",
  "tag": "section",
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "Image URL (fallback)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "range",
          "id": "focal_x",
          "min": 0,
          "max": 100,
          "step": 5,
          "unit": "%",
          "label": "Focal point X",
          "default": 50
        },
        {
          "type": "range",
          "id": "focal_y",
          "min": 0,
          "max": 100,
          "step": 5,
          "unit": "%",
          "label": "Focal point Y",
          "default": 50
        },
        {
          "type": "range",
          "id": "scale",
          "min": 100,
          "max": 150,
          "step": 5,
          "unit": "%",
          "label": "Zoom / scale",
          "default": 100
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Homepage: Discover Tiles"
    }
  ]
}
{% endschema %}
