{{ 'bjerrehuus-homepage.css' | asset_url | stylesheet_tag }}

{%- if section.blocks.size > 0 -%}
<section class="bjfj-tiles">
  <div class="bjfj-tiles__grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'tile' -%}
        <a
          href="{{ block.settings.link }}"
          class="bjfj-tile"
          aria-label="{{ block.settings.label | escape }}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 800
              | image_tag:
                class: 'bjfj-tile__img',
                loading: 'lazy',
                alt: block.settings.label | escape
            }}
          {%- elsif block.settings.image_url != blank -%}
            <img
              src="{{ block.settings.image_url | escape }}"
              class="bjfj-tile__img"
              loading="lazy"
              alt="{{ block.settings.label | escape }}"
            >
          {%- else -%}
            {{ 'lifestyle' | placeholder_svg_tag: 'bjfj-tile__img' }}
          {%- endif -%}
          <div class="bjfj-tile__scrim"></div>
          {%- if block.settings.label != blank -%}
            <span class="bjfj-tile__label">{{ block.settings.label }}</span>
          {%- endif -%}
        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Homepage: Discover Tiles",
  "tag": "section",
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "Image URL (fallback)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Homepage: Discover Tiles"
    }
  ]
}
{% endschema %}
