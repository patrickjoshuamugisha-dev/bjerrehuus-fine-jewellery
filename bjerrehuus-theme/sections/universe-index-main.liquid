{{ 'bjerrehuus-inspiration.css' | asset_url | stylesheet_tag }}

<section class="bjfj-universe-index-section bjfj-universe-index">
  <div class="bjfj-universe-index-inner">

    <div class="bjfj-universe-index__header bjfj-reveal">
      <p class="bjfj-universe-index__eyebrow">{{ section.settings.eyebrow | default: 'Universe' }}</p>
      <h1 class="bjfj-universe-index__heading">{{ section.settings.heading | default: page.title }}</h1>
      {%- if section.settings.intro != blank -%}
        <div class="bjfj-universe-index__intro">{{ section.settings.intro }}</div>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <ul class="bjfj-universe-index__list" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'story_link' -%}
            {%- liquid
              assign story_page = pages[block.settings.story_handle]
              assign story_title = block.settings.story_title | default: story_page.title
              assign story_url   = block.settings.story_url | default: story_page.url
            -%}
            <li class="bjfj-universe-index__item bjfj-reveal" {{ block.shopify_attributes }}>
              <a
                href="{{ story_url | default: '#' }}"
                class="bjfj-universe-index__link"
              >
                {%- if block.settings.story_image != blank -%}
                  {{
                    block.settings.story_image
                    | image_url: width: 300
                    | image_tag:
                      class: 'bjfj-universe-index__thumb',
                      loading: 'lazy',
                      alt: story_title
                  }}
                {%- elsif block.settings.story_image_url != blank -%}
                  <img src="{{ block.settings.story_image_url }}" class="bjfj-universe-index__thumb" loading="lazy" alt="{{ story_title | escape }}">
                {%- else -%}
                  <div class="bjfj-universe-index__thumb" style="background:var(--bjfj-bg-alt);"></div>
                {%- endif -%}

                <span class="bjfj-universe-index__story-title">{{ story_title }}</span>

                {%- if block.settings.story_date != blank -%}
                  <span class="bjfj-universe-index__story-date">{{ block.settings.story_date }}</span>
                {%- endif -%}
              </a>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- else -%}
      <p style="font-family:var(--bjfj-font-body);color:var(--bjfj-text-muted);padding:var(--bjfj-s-8) 0;">
        No stories yet. Add story links in the section settings.
      </p>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Universe Index",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Universe"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Page heading",
      "info": "Defaults to the page title if left blank"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro text"
    }
  ],
  "blocks": [
    {
      "type": "story_link",
      "name": "Story",
      "settings": [
        {
          "type": "image_picker",
          "id": "story_image",
          "label": "Story thumbnail"
        },
        {
          "type": "text",
          "id": "story_image_url",
          "label": "Thumbnail URL (fallback)"
        },
        {
          "type": "text",
          "id": "story_title",
          "label": "Story title"
        },
        {
          "type": "text",
          "id": "story_date",
          "label": "Date",
          "placeholder": "April 2025"
        },
        {
          "type": "text",
          "id": "story_handle",
          "label": "Page handle",
          "info": "The page handle from Shopify admin (e.g. 'universe-story-1')"
        },
        {
          "type": "url",
          "id": "story_url",
          "label": "Story URL",
          "info": "Direct URL — overrides the handle lookup above"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Universe Index"
    }
  ]
}
{% endschema %}
